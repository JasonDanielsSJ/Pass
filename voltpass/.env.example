# Database
DATABASE_URL=postgresql://user:password@localhost:5432/voltpass

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-here

# Issuer
ISSUER_DID=did:voltpass:issuer
ISSUER_PRIVATE_KEY=base64-encoded-ed25519-private-key
ISSUER_PUBLIC_KEY=base64-encoded-ed25519-public-key

# Resend (email)
RESEND_API_KEY=re_your_key_here

# FCM (push notifications)
FCM_SERVER_KEY=your-fcm-server-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRO_PRICE_ID=price_electrician_pro
STRIPE_EMPLOYER_PRICE_ID=price_employer_seat

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ISSUER_PUBLIC_KEY=base64-encoded-ed25519-public-key

# Expo
EXPO_PUBLIC_API_URL=http://localhost:3001
